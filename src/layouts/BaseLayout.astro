---
import BaseHead from "../components/layout/BaseHead.astro";
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import WhatsAppButton from "../components/ui/WhatsAppButton.astro";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";
import restaurantDataIt from "../data/restaurant.json";
import restaurantDataEn from "../data/en/restaurant.json";
import { t, type Lang } from "../i18n/ui";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  transparentNav?: boolean;
  lang?: Lang;
  breadcrumbs?: Array<{ label: string; href?: string }>;
  breadcrumbsOverlay?: boolean;
}

const { title, description, ogImage, ogType, transparentNav = false, lang = "it", breadcrumbs, breadcrumbsOverlay = false } = Astro.props;
const currentPath = Astro.url.pathname;
const restaurantData = lang === "en" ? restaurantDataEn : restaurantDataIt;

const pathMap: Record<string, string> = {
  "/": "/en/",
  "/menu/": "/en/menu/",
  "/chi-siamo/": "/en/about-us/",
  "/galleria/": "/en/gallery/",
  "/la-cantina/": "/en/wine-cellar/",
  "/contatti/": "/en/contact/",
  "/prenota/": "/en/book/",
  "/en/": "/",
  "/en/menu/": "/menu/",
  "/en/about-us/": "/chi-siamo/",
  "/en/gallery/": "/galleria/",
  "/en/wine-cellar/": "/la-cantina/",
  "/en/contact/": "/contatti/",
  "/en/book/": "/prenota/",
};
const alternatePath = pathMap[currentPath] || currentPath;
const alternateUrl = `https://taverna-del-porto.vercel.app${alternatePath}`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <BaseHead title={title} description={description} ogImage={ogImage} ogType={ogType} />
    <link rel="alternate" hreflang={lang === "it" ? "en" : "it"} href={alternateUrl} />
    <link rel="alternate" hreflang={lang} href={`https://taverna-del-porto.vercel.app${currentPath}`} />
  </head>
  <body class="bg-sand text-text font-body min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">{t(lang, "common.skipLink")}</a>
    <Navbar currentPath={currentPath} transparent={transparentNav} lang={lang} />
    <main id="main-content" class="flex-1 relative">
      {breadcrumbs && (
        <div class:list={[
          "pt-24 md:pt-28 pb-4",
          breadcrumbsOverlay
            ? "absolute top-0 left-0 right-0 z-20 pointer-events-none"
            : "bg-sand border-b border-sand-dark/50",
        ]}>
          <div class="mx-auto max-w-7xl px-4 md:px-8 pointer-events-auto">
            <Breadcrumbs items={breadcrumbs} light={breadcrumbsOverlay} />
          </div>
        </div>
      )}
      <slot />
    </main>
    <Footer lang={lang} />
    <WhatsAppButton
      phoneNumber={restaurantData.whatsapp}
      message={restaurantData.whatsappMessage}
      lang={lang}
    />

    <!-- Global scroll reveal + parallax -->
    <script>
      document.addEventListener("astro:page-load", () => {
        // Scroll reveal via IntersectionObserver
        // Delay observer setup so view transitions finish before reveals fire
        const revealElements = document.querySelectorAll<HTMLElement>("[data-reveal]");
        if (revealElements.length > 0) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("revealed");
                observer.unobserve(entry.target);
              }
            });
          }, { threshold: 0.1, rootMargin: "0px 0px -40px 0px" });

          setTimeout(() => {
            revealElements.forEach((el) => observer.observe(el));
          }, 150);
        }

        // Parallax effect
        const parallaxBgs = document.querySelectorAll<HTMLElement>(".parallax-bg");
        if (parallaxBgs.length > 0) {
          function updateParallax() {
            parallaxBgs.forEach((bg) => {
              const section = bg.parentElement;
              if (!section) return;
              const rect = section.getBoundingClientRect();
              const vh = window.innerHeight;
              if (rect.bottom < 0 || rect.top > vh) return;
              const progress = (vh - rect.top) / (vh + rect.height);
              const offset = (progress - 0.5) * 150;
              bg.style.transform = `translate3d(0, ${offset}px, 0)`;
            });
          }
          window.addEventListener("scroll", updateParallax, { passive: true });
          updateParallax();
        }
      });
    </script>
  </body>
</html>
