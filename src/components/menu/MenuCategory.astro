---
import MenuItem from "./MenuItem.astro";

interface Props {
  name: string;
  items: Array<{ name: string; description: string; price: number; tags?: string[]; allergens?: string[] }>;
  allergenLabels?: Record<string, string>;
  index?: number;
}

const { name, items, allergenLabels, index = 0 } = Astro.props;
const slug = name.toLowerCase().replace(/\s+/g, "-");
const reveal = index % 2 === 0 ? "fade-right" : "fade-left";
---

<section id={slug} class="scroll-mt-[18rem] md:scroll-mt-[15rem]">
  <div data-reveal={reveal}>
    <h2 class="font-heading text-2xl font-bold text-navy mb-2 md:text-3xl text-center">{name}</h2>
    <div class="h-0.5 w-10 bg-gold mb-6 mx-auto"></div>
    <div>
      {items.map((item) => (
        <MenuItem name={item.name} description={item.description} price={item.price} tags={item.tags} allergens={item.allergens} allergenLabels={allergenLabels} />
      ))}
    </div>
  </div>
</section>
