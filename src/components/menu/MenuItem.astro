---
interface Props {
  name: string;
  description: string;
  price: number;
  tags?: string[];
}

const { name, description, price, tags = [] } = Astro.props;

const tagColors: Record<string, string> = {
  "pesce del giorno": "bg-navy/10 text-navy",
  "piccante": "bg-brick/10 text-brick",
  "speciale": "bg-gold/10 text-gold",
  "tradizione": "bg-navy/10 text-navy",
  "vegetariano": "bg-green-100 text-green-800",
};
---

<div class="group py-4 border-b border-sand-dark last:border-0">
  <div class="flex items-baseline gap-2">
    <h3 class="font-heading text-lg font-semibold text-navy md:text-xl shrink-0">{name}</h3>
    <span class="flex-1 border-b border-dotted border-text-light/30 translate-y-[-4px]"></span>
    <span class="font-body text-base font-bold text-gold shrink-0 md:text-lg">&euro;{price.toFixed(2)}</span>
  </div>
  <p class="mt-1 text-sm text-text-light leading-relaxed">{description}</p>
  {tags.length > 0 && (
    <div class="mt-2 flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class:list={[
          "inline-block rounded-full px-3 py-0.5 text-xs font-semibold capitalize",
          tagColors[tag] || "bg-sand-dark text-text-light",
        ]}>
          {tag}
        </span>
      ))}
    </div>
  )}
</div>
