---
interface Props {
  phoneNumber: string;
  message?: string;
  lang?: "it" | "en";
}

const { phoneNumber, message = "", lang = "it" } = Astro.props;
const ariaLabel = lang === "en" ? "Chat on WhatsApp" : "Scrivici su WhatsApp";
const tooltip = lang === "en" ? "Chat with us" : "Scrivici";
const encodedMessage = encodeURIComponent(message);
const href = `https://wa.me/${phoneNumber.replace(/[^0-9]/g, "")}${encodedMessage ? `?text=${encodedMessage}` : ""}`;
---

<div
  class="wa-fab fixed bottom-6 right-6 z-50 flex items-center gap-3"
  style="bottom: calc(1.5rem + env(safe-area-inset-bottom, 0px));"
  data-wa-fab
>
  <span class="wa-tooltip pointer-events-none hidden md:inline-block bg-navy text-white text-sm font-semibold px-4 py-2 shadow-lg whitespace-nowrap opacity-0 translate-x-2 transition-all duration-300">
    {tooltip}
  </span>

  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={ariaLabel}
    class="wa-btn group relative flex h-16 w-16 items-center justify-center text-white shadow-xl transition-all duration-300 hover:shadow-2xl hover:scale-110 focus:outline-none focus-visible:ring-4 focus-visible:ring-gold/60"
  >
    <span class="wa-ring absolute inset-0" aria-hidden="true"></span>

    <svg class="relative h-7 w-7 md:h-8 md:w-8 drop-shadow-sm" viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
    </svg>
    <span class="sr-only">{ariaLabel}</span>
  </a>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const fab = document.querySelector<HTMLElement>("[data-wa-fab]");
    const hero = document.querySelector<HTMLElement>("[data-hero]");
    if (!fab) return;
    if (!hero) {
      fab.classList.remove("wa-hidden");
      return;
    }
    const observer = new IntersectionObserver(
      ([entry]) => {
        fab.classList.toggle("wa-hidden", entry.isIntersecting);
      },
      { threshold: 0.05 }
    );
    observer.observe(hero);
  });
</script>

<style>
  .wa-btn {
    border-radius: 9999px !important;
    background: linear-gradient(135deg, #25D366 0%, #128C7E 100%);
  }
  .wa-fab {
    transition: opacity 300ms ease, transform 300ms ease;
  }
  .wa-fab.wa-hidden {
    opacity: 0;
    transform: translateY(1rem);
    pointer-events: none;
  }
  .wa-tooltip {
    border-radius: 9999px !important;
  }
  .wa-btn:hover + .wa-tooltip,
  .wa-fab:hover .wa-tooltip {
    opacity: 1;
    transform: translateX(0);
  }
  .wa-ring {
    border-radius: 9999px !important;
    background-color: #25D366;
    opacity: 0;
    animation: wa-ping 6s cubic-bezier(0, 0, 0.2, 1) infinite;
  }
  @keyframes wa-ping {
    0%, 70%, 100% { transform: scale(1); opacity: 0; }
    78% { transform: scale(1.15); opacity: 0.3; }
    100% { transform: scale(1.4); opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .wa-ring { animation: none; opacity: 0; }
    .wa-btn { transition: none; }
  }
</style>
