---
interface Props {
  title: string;
  subtitle?: string;
  align?: "left" | "center";
  light?: boolean;
}

const { title, subtitle, align = "center", light = false } = Astro.props;
---

<div class:list={["mb-12", align === "center" ? "text-center" : "text-left"]}>
  <h2
    class:list={[
      "font-heading text-2xl md:text-[2.75rem] font-bold leading-tight",
      light ? "text-white" : "text-navy",
    ]}
  >
    {title}
  </h2>
  <div
    class:list={[
      "mt-3 h-0.5 w-10",
      light ? "bg-gold-light" : "bg-gold",
      align === "center" ? "mx-auto" : "",
    ]}
  ></div>
  {subtitle && (
    <p
      class:list={[
        "mt-4 text-lg max-w-2xl",
        light ? "text-white/80" : "text-text-light",
        align === "center" ? "mx-auto" : "",
      ]}
    >
      {subtitle}
    </p>
  )}
</div>
