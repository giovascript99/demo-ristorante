---
interface Props {
  lat: number;
  lng: number;
  zoom?: number;
  title?: string;
}

const { lat, lng, zoom = 15, title = "Mappa" } = Astro.props;
const src = `https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d3000!2d${lng}!3d${lat}!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1sen!2sit!4v1`;
---

<div class="rounded-lg overflow-hidden shadow-md h-60 sm:h-72 md:h-96">
  <iframe
    src={src}
    width="100%"
    height="100%"
    style="border:0;"
    allowfullscreen=""
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    title={title}
  ></iframe>
</div>
