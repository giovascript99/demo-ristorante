---
interface Props {
  animation?: "fade-up" | "fade-in" | "slide-left" | "slide-right" | "clip-reveal";
  class?: string;
}

const { animation = "fade-up", class: className = "" } = Astro.props;

const animationClass = `animate-${animation}`;
---

<div class:list={[animationClass, className]}>
  <slot />
</div>
