---
import menuData from "../../data/menu.json";
import PlaceholderImage from "../ui/PlaceholderImage.astro";

const featuredDishes = menuData.categories
  .flatMap((cat) => cat.items)
  .filter((item) => item.featured)
  .slice(0, 3);
---

<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
  {featuredDishes.map((dish, i) => (
    <article class:list={[
      "group rounded-xl bg-white shadow-sm overflow-hidden transition-all duration-300 hover:shadow-lg hover:-translate-y-1 border border-sand-dark",
      `animate-fade-up animate-delay-${(i + 1) * 100}`,
    ]}>
      <PlaceholderImage
        alt={dish.name}
        description={`Foto del piatto: ${dish.name} - ${dish.description}`}
        aspectRatio="4/3"
        class="w-full"
      />
      <div class="p-6">
        <h3 class="font-heading text-lg font-semibold text-navy">{dish.name}</h3>
        <p class="mt-1 text-sm text-text-light leading-relaxed">{dish.description}</p>
        <p class="mt-3 text-lg font-bold text-gold">&euro;{dish.price.toFixed(2)}</p>
      </div>
    </article>
  ))}
</div>
