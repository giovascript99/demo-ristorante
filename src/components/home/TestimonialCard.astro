---
interface Props {
  name: string;
  text: string;
  rating: number;
}

const { name, text, rating } = Astro.props;
---

<article class="flex-shrink-0 w-80 snap-center rounded-xl border border-gold/20 bg-white p-8 shadow-sm md:w-auto md:snap-align-none">
  <!-- Quote mark -->
  <svg class="h-8 w-8 text-gold/30 mb-4" fill="currentColor" viewBox="0 0 24 24">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10H0z"/>
  </svg>
  <p class="text-text leading-relaxed italic">&ldquo;{text}&rdquo;</p>
  <!-- Stars -->
  <div class="mt-4 flex gap-1">
    {Array.from({ length: 5 }).map((_, i) => (
      <svg
        class:list={["h-5 w-5", i < rating ? "text-gold" : "text-sand-dark"]}
        fill="currentColor" viewBox="0 0 20 20"
      >
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292z"/>
      </svg>
    ))}
  </div>
  <p class="mt-3 text-sm font-semibold text-navy">{name}</p>
</article>
