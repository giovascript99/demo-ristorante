---
interface Props {
  recipientEmail?: string;
}

const { recipientEmail = "" } = Astro.props;
---

<!--
  INTEGRATION: To enable form submissions, choose one:

  1. Netlify Forms: Uncomment data-netlify="true" and netlify-honeypot="bot-field" on the <form>.
     Deploy to Netlify and submissions will appear in the Netlify dashboard.

  2. Formspree: Add action="https://formspree.io/f/YOUR_ID" and method="POST" to the <form>.
     Remove the JS submit handler below.

  3. Custom backend: Point the form action to your API endpoint.
-->
<form
  id="contact-form"
  class="space-y-6"
  novalidate
>
  <!-- Honeypot (anti-spam, hidden) -->
  <div class="hidden" aria-hidden="true">
    <label>Non compilare questo campo <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label>
  </div>

  <div>
    <label for="name" class="block text-sm font-semibold text-navy mb-1">Nome *</label>
    <input
      type="text" id="name" name="name" required autocomplete="name"
      class="w-full rounded-md border border-sand-dark bg-white px-4 py-3 text-text transition-colors focus:border-gold focus:outline-none focus:ring-2 focus:ring-gold/20"
    />
  </div>

  <div>
    <label for="email" class="block text-sm font-semibold text-navy mb-1">Email *</label>
    <input
      type="email" id="email" name="email" required autocomplete="email"
      class="w-full rounded-md border border-sand-dark bg-white px-4 py-3 text-text transition-colors focus:border-gold focus:outline-none focus:ring-2 focus:ring-gold/20"
    />
  </div>

  <div>
    <label for="phone" class="block text-sm font-semibold text-navy mb-1">Telefono</label>
    <input
      type="tel" id="phone" name="phone" autocomplete="tel"
      class="w-full rounded-md border border-sand-dark bg-white px-4 py-3 text-text transition-colors focus:border-gold focus:outline-none focus:ring-2 focus:ring-gold/20"
    />
  </div>

  <div>
    <label for="message" class="block text-sm font-semibold text-navy mb-1">Messaggio *</label>
    <textarea
      id="message" name="message" required rows="5"
      class="w-full rounded-md border border-sand-dark bg-white px-4 py-3 text-text transition-colors focus:border-gold focus:outline-none focus:ring-2 focus:ring-gold/20 resize-y"
    ></textarea>
  </div>

  <button
    type="submit"
    class="w-full sm:w-auto rounded-md bg-gold px-8 py-3 font-bold text-white transition-all hover:bg-gold-light hover:scale-[1.02] hover:shadow-md focus:outline-2 focus:outline-offset-2 focus:outline-gold"
  >
    Invia Messaggio
  </button>
</form>

<!-- Success message (hidden by default) -->
<div id="form-success" class="hidden rounded-xl border border-gold/30 bg-gold/5 p-8 text-center">
  <svg class="mx-auto h-12 w-12 text-gold mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
  </svg>
  <h3 class="font-heading text-xl font-bold text-navy">Messaggio inviato!</h3>
  <p class="mt-2 text-text-light">Grazie per averci contattato. Ti risponderemo il prima possibile.</p>
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const form = document.getElementById("contact-form");
    const success = document.getElementById("form-success");

    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      form.classList.add("hidden");
      success?.classList.remove("hidden");
    });
  });
</script>
