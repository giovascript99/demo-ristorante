---
interface Props {
  images: Array<{ src: string; alt: string; category: string; width: number; height: number; description: string }>;
}

const { images } = Astro.props;

// Bento layout: 12 items on 4-col grid = 20 cells = 5 full rows, no orphan.
// Pattern: 2×(2x2 feature) + 1×(1x2 tall) + 1×(2x1 wide) + 8×(1x1) = 4+4+2+2+8 = 20.
// Mobile/tablet ignore spans — uniform grid.
function spanClass(i: number): string {
  if (i === 0 || i === 8) return "lg:col-span-2 lg:row-span-2";
  if (i === 2) return "lg:row-span-2";
  if (i === 5) return "lg:col-span-2";
  return "";
}
---

<div class="grid grid-flow-row-dense gap-3 sm:gap-4 grid-cols-2 lg:grid-cols-4 auto-rows-[180px] sm:auto-rows-[200px] lg:auto-rows-[220px]">
  {images.map((img, i) => (
    <button
      type="button"
      class:list={[
        "gallery-item group relative overflow-hidden cursor-pointer focus:outline-2 focus:outline-offset-2 focus:outline-gold",
        spanClass(i),
      ]}
      data-reveal="fade-up"
      data-gallery-index={i}
      aria-label={`Apri foto: ${img.alt}`}
    >
      <img
        src={img.src}
        alt={img.alt}
        width={img.width}
        height={img.height}
        loading={i < 4 ? "eager" : "lazy"}
        draggable="false"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105 pointer-events-none"
      />
      <!-- Gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-t from-navy/80 via-navy/0 to-navy/0 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
      <!-- Caption + zoom icon -->
      <div class="absolute inset-x-0 bottom-0 p-4 translate-y-2 opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
        <p class="text-white text-sm font-semibold leading-snug drop-shadow-md line-clamp-2">{img.alt}</p>
        <span class="mt-1 inline-block text-[0.7rem] uppercase tracking-wider text-gold">{img.category}</span>
      </div>
      <div class="absolute top-3 right-3 flex h-9 w-9 items-center justify-center bg-white/90 text-navy opacity-0 translate-y-1 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607ZM10.5 7.5v6m3-3h-6" />
        </svg>
      </div>
    </button>
  ))}
</div>
