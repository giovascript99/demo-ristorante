---
import restaurantDataIt from "../../data/restaurant.json";
import restaurantDataEn from "../../data/en/restaurant.json";
import { t, type Lang } from "../../i18n/ui";

interface Props {
  lang?: Lang;
}

const { lang = "it" } = Astro.props;
const restaurantData = lang === "en" ? restaurantDataEn : restaurantDataIt;
const year = new Date().getFullYear();

const links = lang === "it"
  ? [
      { label: "Home", href: "/" },
      { label: "Menu", href: "/menu/" },
      { label: "La Cantina", href: "/la-cantina/" },
      { label: "Chi Siamo", href: "/chi-siamo/" },
      { label: "Galleria", href: "/galleria/" },
      { label: "Prenota", href: "/prenota/" },
      { label: "Contatti", href: "/contatti/" },
    ]
  : [
      { label: "Home", href: "/en/" },
      { label: "Menu", href: "/en/menu/" },
      { label: "Wine Cellar", href: "/en/wine-cellar/" },
      { label: "About Us", href: "/en/about-us/" },
      { label: "Gallery", href: "/en/gallery/" },
      { label: "Book", href: "/en/book/" },
      { label: "Contact", href: "/en/contact/" },
    ];
---

<footer class="bg-navy text-white">
  <div class="mx-auto max-w-7xl px-4 py-16 md:px-8">
    <!-- Newsletter -->
    <div class="mb-12 pb-12 border-b border-white/10">
      <div class="max-w-xl mx-auto text-center">
        <h3 class="font-heading text-xl font-bold text-gold mb-2">{t(lang, "footer.newsletter.title")}</h3>
        <p class="text-sm text-white/70 mb-6">{t(lang, "footer.newsletter.text")}</p>
        <form id="newsletter-form" class="flex flex-col gap-3 sm:flex-row">
          <input
            type="email"
            name="email"
            required
            placeholder={t(lang, "footer.newsletter.placeholder")}
            autocomplete="email"
            class="flex-1 rounded-md bg-white/10 border border-white/20 px-4 py-3 text-sm text-white placeholder-white/50 transition-colors focus:border-gold focus:outline-none focus:ring-2 focus:ring-gold/20"
          />
          <button
            type="submit"
            class="shrink-0 rounded-md bg-gold px-6 py-3 text-sm font-bold text-white transition-all hover:bg-gold-light hover:scale-[1.02]"
          >
            {t(lang, "footer.newsletter.button")}
          </button>
        </form>
        <p id="newsletter-success" class="hidden mt-3 text-sm text-gold">{t(lang, "footer.newsletter.success")}</p>
      </div>
    </div>

    <div class="grid gap-12 sm:grid-cols-2 md:grid-cols-3">
      <!-- Contact info -->
      <div>
        <h3 class="font-heading text-xl font-bold text-gold mb-4">{restaurantData.name}</h3>
        <address class="not-italic space-y-2 text-white/80 text-sm leading-relaxed">
          <p>{restaurantData.address.street}</p>
          <p>{restaurantData.address.cap} {restaurantData.address.city} ({restaurantData.address.province})</p>
          <p class="pt-2">
            <a href={`tel:${restaurantData.phone}`} class="transition-colors hover:text-gold">
              {restaurantData.phone}
            </a>
          </p>
          <p>
            <a href={`mailto:${restaurantData.email}`} class="transition-colors hover:text-gold">
              {restaurantData.email}
            </a>
          </p>
        </address>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="font-heading text-xl font-bold text-gold mb-4">{t(lang, "footer.links")}</h3>
        <ul class="space-y-2 text-sm text-white/80">
          {links.map((link) => (
            <li><a href={link.href} class="transition-colors hover:text-gold">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Social -->
      <div>
        <h3 class="font-heading text-xl font-bold text-gold mb-4">{t(lang, "footer.follow")}</h3>
        <div class="flex gap-4">
          <a href={restaurantData.social.facebook} aria-label="Facebook" class="flex h-11 w-11 items-center justify-center rounded-full border border-white/20 text-white/80 transition-all hover:border-gold hover:text-gold">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={restaurantData.social.instagram} aria-label="Instagram" class="flex h-11 w-11 items-center justify-center rounded-full border border-white/20 text-white/80 transition-all hover:border-gold hover:text-gold">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
          <a href={restaurantData.social.tripadvisor} aria-label="TripAdvisor" class="flex h-11 w-11 items-center justify-center rounded-full border border-white/20 text-white/80 transition-all hover:border-gold hover:text-gold">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.006 4.295c-2.67 0-5.338.784-7.645 2.353H0l1.963 2.135a5.997 5.997 0 0 0 4.04 10.43 5.976 5.976 0 0 0 4.075-1.6L12 19.51l1.922-1.897a5.976 5.976 0 0 0 4.075 1.6 5.997 5.997 0 0 0 4.04-10.43L24 6.648h-4.35a13.573 13.573 0 0 0-7.644-2.353zM6.003 17.213a3.997 3.997 0 1 1 0-7.994 3.997 3.997 0 0 1 0 7.994zm11.994 0a3.997 3.997 0 1 1 0-7.994 3.997 3.997 0 0 1 0 7.994zM6.003 11.219a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm11.994 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 border-t border-white/10 pt-8 text-center text-sm text-white/50">
      <p>&copy; {year} {restaurantData.name}. {t(lang, "footer.rights")}</p>
      <p class="mt-1">P.IVA {restaurantData.vatNumber}</p>
    </div>
  </div>
</footer>

<script>
  // Newsletter form — placeholder UI only. Connect to Mailchimp/Brevo/etc. when deploying for a real client.
  document.addEventListener("astro:page-load", () => {
    const form = document.getElementById("newsletter-form");
    const success = document.getElementById("newsletter-success");
    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      form.classList.add("hidden");
      success?.classList.remove("hidden");
    });
  });
</script>
