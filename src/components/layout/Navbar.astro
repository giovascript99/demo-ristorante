---
import restaurantDataIt from "../../data/restaurant.json";
import restaurantDataEn from "../../data/en/restaurant.json";

interface Props {
  currentPath: string;
  transparent?: boolean;
  lang?: "it" | "en";
}

const { currentPath, transparent = false, lang = "it" } = Astro.props;

const pathMap: Record<string, string> = {
  "/": "/en/",
  "/menu/": "/en/menu/",
  "/chi-siamo/": "/en/about-us/",
  "/galleria/": "/en/gallery/",
  "/la-cantina/": "/en/wine-cellar/",
  "/contatti/": "/en/contact/",
  "/prenota/": "/en/book/",
  "/en/": "/",
  "/en/menu/": "/menu/",
  "/en/about-us/": "/chi-siamo/",
  "/en/gallery/": "/galleria/",
  "/en/wine-cellar/": "/la-cantina/",
  "/en/contact/": "/contatti/",
  "/en/book/": "/prenota/",
};

const alternateLang = lang === "it" ? "en" : "it";
const alternateHref = pathMap[currentPath] || (lang === "it" ? `/en${currentPath}` : currentPath.replace(/^\/en/, ""));

const navLinks = lang === "it"
  ? [
      { label: "Home", href: "/" },
      { label: "Menu", href: "/menu/" },
      { label: "La Cantina", href: "/la-cantina/" },
      { label: "Chi Siamo", href: "/chi-siamo/" },
      { label: "Galleria", href: "/galleria/" },
      { label: "Contatti", href: "/contatti/" },
    ]
  : [
      { label: "Home", href: "/en/" },
      { label: "Menu", href: "/en/menu/" },
      { label: "Wine Cellar", href: "/en/wine-cellar/" },
      { label: "About Us", href: "/en/about-us/" },
      { label: "Gallery", href: "/en/gallery/" },
      { label: "Contact", href: "/en/contact/" },
    ];

const restaurantData = lang === "en" ? restaurantDataEn : restaurantDataIt;
const homeHref = lang === "en" ? "/en/" : "/";
const whatsappHref = `https://wa.me/${restaurantData.whatsapp.replace(/[^0-9]/g, "")}?text=${encodeURIComponent(restaurantData.whatsappMessage)}`;
const bookingHref = lang === "en" ? "/en/book/" : "/prenota/";
---

<nav
  id="main-nav"
  class:list={[
    "fixed top-0 left-0 right-0 z-40 transition-all duration-300",
    !transparent && "nav-scrolled",
  ]}
  data-transparent={transparent ? "true" : "false"}
>
  <div class="flex w-full items-center justify-between px-4 py-4 lg:px-10 xl:px-14" style="padding-top: max(1rem, env(safe-area-inset-top, 1rem))">
    <!-- Logo / Name with decorative anchor -->
    <a href={homeHref} class="group flex items-center gap-2.5">
      <svg class="h-7 w-7 text-gold transition-transform duration-300 group-hover:rotate-12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2C12 2 8 6 8 10c0 2.21 1.79 4 4 4s4-1.79 4-4c0-4-4-8-4-8Z" />
        <path d="M12 14v8" />
        <path d="M8 18h8" />
        <path d="M9 22h6" />
      </svg>
      <div class="flex flex-col">
        <span class="font-heading text-xl font-bold text-white leading-tight lg:text-2xl">
          {restaurantData.name}
        </span>
        <span class="hidden text-[0.625rem] font-semibold uppercase tracking-[0.2em] text-gold/70 lg:block">
          dal {restaurantData.foundedYear}
        </span>
      </div>
    </a>

    <!-- Desktop nav links -->
    <ul class="nav-links hidden items-center gap-10 xl:gap-12 lg:flex">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "nav-link relative py-2 text-[0.9375rem] font-semibold text-white/90 transition-colors hover:text-gold",
              currentPath === link.href && "nav-link-active text-gold",
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Lang switch + CTA + Hamburger -->
    <div class="flex items-center gap-4">
      <!-- Language switcher -->
      <a
        href={alternateHref}
        class="hidden lg:inline-flex items-center gap-1.5 rounded-full border border-white/20 px-3 py-1.5 text-xs font-bold uppercase tracking-wider text-white/80 transition-all hover:border-gold/60 hover:text-gold"
        aria-label={lang === "it" ? "Switch to English" : "Passa all'italiano"}
      >
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
        </svg>
        {alternateLang.toUpperCase()}
      </a>

      <a
        href={bookingHref}
        class="nav-cta group hidden items-center gap-2 bg-gold px-6 py-2.5 text-sm font-bold uppercase tracking-wider text-white shadow-md transition-all duration-300 hover:bg-gold-light hover:shadow-lg hover:-translate-y-0.5 lg:inline-flex"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
        </svg>
        {lang === "it" ? "Prenota" : "Book"}
      </a>

      <!-- Hamburger button (mobile) -->
      <button
        id="hamburger-btn"
        class="flex h-11 w-11 items-center justify-center rounded-md text-white lg:hidden"
        aria-label="Apri menu di navigazione"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="hamburger-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="close-icon" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile menu overlay — OUTSIDE nav to avoid backdrop-filter containing block issue -->
<div
  id="mobile-menu"
  class="pointer-events-none invisible fixed inset-0 z-50 flex flex-col items-center justify-center bg-navy/95 backdrop-blur-sm opacity-0 transition-all duration-300 ease-out lg:hidden"
>
  <!-- Close button -->
  <button
    id="mobile-close-btn"
    class="absolute top-5 right-5 flex h-11 w-11 items-center justify-center text-white"
    aria-label="Chiudi menu"
  >
    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Nav links with gold separators -->
  <nav class="flex flex-col items-center gap-1">
    {navLinks.map((link, i) => (
      <>
        {i > 0 && (
          <div class="flex items-center gap-2 py-2 translate-y-4 opacity-0" aria-hidden="true">
            <span class="h-px w-6 bg-gold/30"></span>
            <span class="block h-1 w-1 rounded-full bg-gold/40"></span>
            <span class="h-px w-6 bg-gold/30"></span>
          </div>
        )}
        <a
          href={link.href}
          class:list={[
            "font-heading text-2xl font-bold text-white transition-all hover:text-gold translate-y-4 opacity-0",
            currentPath === link.href && "text-gold",
          ]}
        >
          {link.label}
        </a>
      </>
    ))}
  </nav>

  <!-- CTA button -->
  <a
    href={bookingHref}
    class="mt-8 rounded-md bg-gold px-8 py-3 text-lg font-bold text-white transition-all hover:bg-gold-light translate-y-4 opacity-0"
  >
    {lang === "it" ? "Prenota" : "Book"}
  </a>

  <!-- Language switcher (mobile) -->
  <a
    href={alternateHref}
    class="mt-6 inline-flex items-center gap-2 rounded-full border border-white/20 px-4 py-2 text-sm font-bold uppercase tracking-wider text-white/70 transition-all hover:border-gold/60 hover:text-gold translate-y-4 opacity-0"
    aria-label={lang === "it" ? "Switch to English" : "Passa all'italiano"}
  >
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
    </svg>
    {alternateLang.toUpperCase()}
  </a>
</div>

<script>
document.addEventListener('astro:page-load', () => {
  const nav = document.getElementById("main-nav");

  // Navbar scroll state + CTA style toggle
  if (nav && nav.dataset.transparent === "true") {
    window.addEventListener("scroll", () => {
      const scrolled = window.scrollY > 50;
      nav.classList.toggle("nav-scrolled", scrolled);
    }, { passive: true });
  }

  // Hamburger toggle
  const hamburgerBtn = document.getElementById("hamburger-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileCloseBtn = document.getElementById("mobile-close-btn");
  const menuItems = mobileMenu?.querySelectorAll("a, [aria-hidden='true']");

  function openMenu() {
    if (!mobileMenu) return;
    mobileMenu.classList.remove("pointer-events-none", "invisible", "opacity-0");
    mobileMenu.classList.add("pointer-events-auto", "opacity-100");
    hamburgerBtn?.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";

    // Stagger animate each link and separator
    menuItems?.forEach((item, i) => {
      setTimeout(() => {
        item.classList.remove("translate-y-4", "opacity-0");
        item.classList.add("translate-y-0", "opacity-100");
      }, 80 + i * 40);
    });
  }

  function closeMenu() {
    if (!mobileMenu) return;
    menuItems?.forEach((item) => {
      item.classList.add("translate-y-4", "opacity-0");
      item.classList.remove("translate-y-0", "opacity-100");
    });
    mobileMenu.classList.remove("pointer-events-auto", "opacity-100");
    mobileMenu.classList.add("opacity-0");
    hamburgerBtn?.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";

    setTimeout(() => {
      mobileMenu.classList.add("pointer-events-none", "invisible");
    }, 300);
  }

  hamburgerBtn?.addEventListener("click", openMenu);
  mobileCloseBtn?.addEventListener("click", closeMenu);

  // Close on link click
  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  // Close on Escape
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !mobileMenu?.classList.contains("invisible")) {
      closeMenu();
    }
  });
});
</script>
