---
import BaseLayout from "../layouts/BaseLayout.astro";
import MenuCategory from "../components/menu/MenuCategory.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";
import menuData from "../data/menu.json";
import seoData from "../data/seo.json";

// JSON-LD Menu schema
const menuJsonLd = {
  "@context": "https://schema.org",
  "@type": "Menu",
  "name": "Menu - Taverna del Porto",
  "url": `${seoData.siteUrl}/menu/`,
  "hasMenuSection": menuData.categories.map((cat) => ({
    "@type": "MenuSection",
    "name": cat.name,
    "hasMenuItem": cat.items.map((item) => ({
      "@type": "MenuItem",
      "name": item.name,
      "description": item.description,
      "offers": {
        "@type": "Offer",
        "price": item.price,
        "priceCurrency": "EUR",
      },
    })),
  })),
};

---

<BaseLayout
  title="Menu | Pesce Fresco a Tropea"
  description="Scopri il nostro menu di pesce fresco: antipasti di mare, primi della tradizione calabrese, secondi alla griglia e dolci fatti in casa."
>
  <!-- JSON-LD Menu Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(menuJsonLd)} />

  <!-- Page header with background image -->
  <section class="relative pt-24 md:pt-32 pb-12 overflow-hidden">
    <img
      src="/images/menu/terrazza-tramonto.jpg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover object-[center_40%]"
    />
    <div class="absolute inset-0 bg-navy/70"></div>
    <div class="relative mx-auto max-w-4xl px-4 md:px-8">
      <div class="mb-6">
        <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Menu" }]} light={true} />
      </div>
      <div data-reveal="fade-up">
        <SectionTitle
          title="Il Nostro Menu"
          subtitle="Pesce fresco del giorno, ricette della tradizione calabrese e ingredienti locali selezionati"
          light={true}
        />
      </div>
    </div>
  </section>

  <!-- Category navigation + dietary filters -->
  <nav class="sticky top-[4.5rem] z-30 bg-sand-dark/95 backdrop-blur-sm border-b border-sand-dark">
    <div class="mx-auto max-w-4xl px-4 md:px-8 py-3">
      <div class="flex flex-wrap items-center justify-center gap-1.5">
        {menuData.categories.map((cat) => (
          <button
            type="button"
            data-scroll-to={cat.name.toLowerCase().replace(/\s+/g, "-")}
            class="cat-link rounded-full px-4 py-1.5 text-sm font-semibold text-text-light transition-colors hover:bg-gold/10 hover:text-navy"
          >
            {cat.name}
          </button>
        ))}
        <!-- Legend info button -->
        <div class="relative">
          <button
            type="button"
            id="legend-toggle"
            class="flex h-7 w-7 items-center justify-center rounded-full text-text-light/70 transition-colors hover:bg-gold/10 hover:text-navy"
            aria-label="Legenda simboli"
            aria-expanded="false"
          >
            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
            </svg>
          </button>
          <div
            id="legend-popup"
            class="invisible absolute right-0 top-full mt-2 rounded-lg border border-sand-dark bg-white px-4 py-3 shadow-lg opacity-0 transition-all duration-200 w-44 z-50"
          >
            <p class="mb-2 text-xs font-semibold text-navy">Legenda</p>
            <ul class="space-y-1.5 text-xs text-text-light">
              <li>🌾 Senza Glutine</li>
              <li>🌱 Vegetariano</li>
              <li>🐟 Crudo</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <!-- Menu categories -->
  <section id="menu-items" class="py-16 bg-sand scroll-mt-[14rem] md:scroll-mt-[11rem]" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(212,168,83,0.03) 39px, rgba(212,168,83,0.03) 40px);">
    <div class="mx-auto max-w-4xl px-4 md:px-8 space-y-16">
      {menuData.categories.map((cat) => (
        <MenuCategory name={cat.name} items={cat.items} allergenLabels={menuData.allergenLabels} />
      ))}
    </div>
  </section>

  <!-- Allergen legend + footer note -->
  <section class="pb-20 bg-sand">
    <div class="mx-auto max-w-4xl px-4 md:px-8 space-y-4 text-center">
      <div class="flex flex-wrap items-center justify-center gap-3 sm:gap-4 rounded-lg border border-sand-dark bg-white px-4 py-2 text-xs text-text-light">
        <span>🌾 Senza Glutine</span>
        <span>🌱 Vegetariano</span>
        <span>🐟 Crudo</span>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-2 rounded-lg border border-sand-dark bg-white px-4 py-2 text-xs text-text-light">
        <svg class="h-4 w-4 text-text-light/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
        </svg>
        <span>Allergeni indicati secondo Reg. UE 1169/2011. Per info dettagliate, chiedere al personale.</span>
      </div>
      <p class="text-sm text-text-light italic">
        Il menu varia in base alla disponibilità del pescato del giorno. Prezzi IVA inclusa.
      </p>
      <a
        href="/menu.pdf"
        download
        class="inline-flex items-center gap-2 rounded-md border border-gold text-gold px-5 py-2 text-sm font-semibold transition-all hover:bg-gold hover:text-navy"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        Scarica il Menu (PDF)
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  document.addEventListener("astro:page-load", () => {
    // Legend popup toggle
    const legendToggle = document.getElementById("legend-toggle");
    const legendPopup = document.getElementById("legend-popup");
    legendToggle?.addEventListener("click", (e) => {
      e.stopPropagation();
      const open = !legendPopup?.classList.contains("invisible");
      if (open) {
        legendPopup?.classList.add("invisible", "opacity-0");
        legendToggle.setAttribute("aria-expanded", "false");
      } else {
        legendPopup?.classList.remove("invisible", "opacity-0");
        legendToggle.setAttribute("aria-expanded", "true");
      }
    });
    document.addEventListener("click", (e) => {
      if (legendToggle?.contains(e.target as Node) || legendPopup?.contains(e.target as Node)) return;
      legendPopup?.classList.add("invisible", "opacity-0");
      legendToggle?.setAttribute("aria-expanded", "false");
    });

    // Category links — scroll so sticky bar stays attached to navbar
    const stickyBar = document.querySelector<HTMLElement>("nav.sticky");
    document.querySelectorAll<HTMLButtonElement>(".cat-link").forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = document.getElementById(btn.dataset.scrollTo!);
        if (target && stickyBar) {
          const stickyTop = parseFloat(getComputedStyle(stickyBar).top) || 0;
          const stickyHeight = stickyBar.offsetHeight;
          const offset = stickyTop + stickyHeight + 24; // 24px breathing room
          const top = target.getBoundingClientRect().top + window.scrollY - offset;
          window.scrollTo({ top, behavior: "smooth" });
        }
      });
    });

  });
</script>
