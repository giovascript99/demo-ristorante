---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import GalleryGrid from "../components/gallery/GalleryGrid.astro";
import Lightbox from "../components/gallery/Lightbox.astro";
import galleryData from "../data/gallery.json";
---

<BaseLayout
  title="Galleria | Foto del Ristorante"
  description="Scopri le foto della Taverna del Porto: i nostri piatti, la sala con vista mare, la cucina e l'atmosfera del ristorante a Tropea."
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Galleria" }]}
>
  <!-- Page header -->
  <section class="pt-10 md:pt-14 pb-16">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div data-reveal="fade-up">
        <SectionTitle
          title="Galleria"
          subtitle="Scopri i nostri piatti, il locale e l'atmosfera della Taverna del Porto"
        />
      </div>
    </div>
  </section>

  <!-- Gallery grid -->
  <section class="pb-20 gallery-grid-wrap">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <GalleryGrid images={galleryData} />
    </div>
  </section>

  <!-- Lightbox -->
  <Lightbox images={galleryData.map((img) => ({ src: img.src, alt: img.alt, description: img.description }))} />
</BaseLayout>

<style is:global>
  .gallery-grid-wrap,
  .gallery-grid-wrap *,
  #lightbox-dialog,
  #lightbox-dialog * {
    user-select: none !important;
    -webkit-user-select: none !important;
    -webkit-user-drag: none !important;
    -webkit-touch-callout: none !important;
  }
  .gallery-grid-wrap ::selection,
  #lightbox-dialog ::selection {
    background: transparent !important;
    color: inherit !important;
  }
  .gallery-grid-wrap img {
    pointer-events: none;
  }
</style>
