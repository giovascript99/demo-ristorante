---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/home/Hero.astro";
import FeaturedDishes from "../components/home/FeaturedDishes.astro";
import TestimonialCard from "../components/home/TestimonialCard.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import AnimateOnScroll from "../components/ui/AnimateOnScroll.astro";
import PlaceholderImage from "../components/ui/PlaceholderImage.astro";
import GoogleMap from "../components/ui/GoogleMap.astro";
import restaurant from "../data/restaurant.json";
import testimonials from "../data/testimonials.json";

const whatsappUrl = `https://wa.me/${restaurant.whatsapp.replace(/\+/g, "")}?text=${encodeURIComponent(restaurant.whatsappMessage)}`;
const phoneHref = `tel:${restaurant.phone.replace(/\s/g, "")}`;
---

<BaseLayout
  title="Ristorante di Pesce a Tropea, Calabria"
  description="Ristorante di pesce con vista mare a Tropea. Cucina calabrese di tradizione con pesce fresco del giorno. Prenota il tuo tavolo."
>
  <!-- 1. Hero -->
  <Hero
    title={restaurant.name}
    subtitle={restaurant.tagline}
    ctaPrimary={{ text: "Scopri il Menu", href: "/menu/" }}
    ctaSecondary={{ text: "Prenota un Tavolo", href: whatsappUrl }}
  />

  <!-- 2. Chi Siamo brief -->
  <section class="py-20 md:py-28">
    <div class="mx-auto max-w-7xl px-4">
      <AnimateOnScroll>
        <div class="grid items-center gap-12 md:grid-cols-2">
          <!-- Text left -->
          <div>
            <h2 class="font-heading text-2xl font-bold text-navy md:text-4xl">
              La Famiglia Ferraro, <br />dal 1985 a Tropea
            </h2>
            <div class="mt-3 h-0.5 w-10 bg-gold"></div>
            <p class="mt-6 text-text-light leading-relaxed">
              Siamo una famiglia di pescatori e cuochi da tre generazioni. Lo chef Marco Ferraro
              ha trasformato le ricette della nonna in una cucina che celebra il mare della Calabria,
              con pesce fresco ogni giorno e ingredienti del territorio.
            </p>
            <p class="mt-4 text-text-light leading-relaxed">
              Ogni piatto racconta una storia di tradizione, di mare, di Tropea. Benvenuti alla
              nostra tavola.
            </p>
            <a
              href="/chi-siamo/"
              class="mt-8 inline-flex items-center gap-1 font-semibold text-gold hover:text-gold-light transition-colors"
            >
              Scopri la nostra storia
              <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
          <!-- Image right -->
          <div class="relative">
            <div class="border-2 border-gold/20 rounded-xl overflow-hidden">
              <PlaceholderImage
                alt="La famiglia Ferraro nel ristorante"
                description="Foto della famiglia Ferraro: chef Marco con i suoi familiari davanti alla Taverna del Porto, terrazza con vista sul mare di Tropea"
                aspectRatio="4/3"
                class="w-full"
              />
            </div>
          </div>
        </div>
      </AnimateOnScroll>
    </div>
  </section>

  <!-- 3. Piatti in Evidenza -->
  <section class="py-20 md:py-28 bg-white">
    <div class="mx-auto max-w-7xl px-4">
      <SectionTitle
        title="I Nostri Piatti in Evidenza"
        subtitle="Scopri i piatti che rendono unica la nostra cucina"
      />
      <FeaturedDishes />
      <div class="mt-12 text-center">
        <a
          href="/menu/"
          class="inline-flex items-center gap-1 font-semibold text-gold hover:text-gold-light transition-colors text-lg"
        >
          Vedi il menu completo
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- 4. Recensioni -->
  <section class="py-20 md:py-28 bg-sand-dark">
    <div class="mx-auto max-w-7xl px-4">
      <SectionTitle title="Cosa Dicono i Nostri Ospiti" />
      <div class="flex overflow-x-auto snap-x snap-mandatory gap-6 pb-4 -mx-4 px-4 md:mx-0 md:px-0 md:grid md:grid-cols-3 md:overflow-visible">
        {testimonials.map((t) => (
          <TestimonialCard name={t.name} text={t.text} rating={t.rating} />
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Orari + Mappa -->
  <section class="py-20 md:py-28">
    <div class="mx-auto max-w-7xl px-4">
      <SectionTitle title="Vieni a Trovarci" />
      <div class="grid gap-12 md:grid-cols-2 items-start">
        <!-- Orari -->
        <div>
          <h3 class="font-heading text-xl font-semibold text-navy mb-6">Orari di Apertura</h3>
          <table class="w-full text-sm border-collapse rounded-lg overflow-hidden shadow-sm">
            <thead>
              <tr class="bg-navy text-white">
                <th class="px-4 py-3 text-left font-semibold">Giorno</th>
                <th class="px-4 py-3 text-left font-semibold">Pranzo</th>
                <th class="px-4 py-3 text-left font-semibold">Cena</th>
              </tr>
            </thead>
            <tbody>
              {restaurant.hours.map((row) => (
                <tr class="even:bg-sand-dark border-b border-sand-dark last:border-0">
                  <td class="px-4 py-3 font-medium text-navy">{row.days}</td>
                  <td class:list={["px-4 py-3", row.lunch === "Chiuso" ? "text-text-light italic" : "text-text"]}>
                    {row.lunch}
                  </td>
                  <td class:list={["px-4 py-3", row.dinner === "Chiuso" ? "text-text-light italic" : "text-text"]}>
                    {row.dinner}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <p class="mt-4 text-sm text-text-light">
            <strong class="text-navy">Indirizzo:</strong> {restaurant.address.street}, {restaurant.address.city} ({restaurant.address.province})
          </p>
          <p class="mt-1 text-sm text-text-light">
            <strong class="text-navy">Telefono:</strong>{" "}
            <a href={phoneHref} class="hover:text-gold transition-colors">{restaurant.phone}</a>
          </p>
        </div>
        <!-- Mappa -->
        <div>
          <GoogleMap
            lat={restaurant.coordinates.lat}
            lng={restaurant.coordinates.lng}
            title={restaurant.name}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CTA Finale -->
  <section class="relative py-20 md:py-28 bg-navy text-white overflow-hidden">
    <div
      class="absolute inset-0 opacity-5"
      style="background-image: repeating-linear-gradient(45deg, transparent, transparent 35px, rgba(255,255,255,.1) 35px, rgba(255,255,255,.1) 70px);"
    ></div>
    <div class="relative mx-auto max-w-7xl px-4 text-center">
      <SectionTitle
        title="Prenota il Tuo Tavolo"
        subtitle="Chiamaci o scrivici su WhatsApp per prenotare"
        light={true}
      />
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href={phoneHref}
          class="rounded-md border-2 border-white px-8 py-3 text-base font-bold text-white transition-all hover:bg-white hover:text-navy"
        >
          {restaurant.phone}
        </a>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-md bg-gold px-8 py-3 text-base font-bold text-navy transition-all hover:bg-gold-light hover:scale-[1.02] hover:shadow-lg"
        >
          Scrivici su WhatsApp
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
