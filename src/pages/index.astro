---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/home/Hero.astro";
import TestimonialCard from "../components/home/TestimonialCard.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import GoogleMap from "../components/ui/GoogleMap.astro";
import restaurant from "../data/restaurant.json";
import testimonials from "../data/testimonials.json";

const whatsappUrl = `https://wa.me/${restaurant.whatsapp.replace(/\+/g, "")}?text=${encodeURIComponent(restaurant.whatsappMessage)}`;
const phoneHref = `tel:${restaurant.phone.replace(/\s/g, "")}`;
---

<BaseLayout
  title="Ristorante di Pesce a Tropea, Calabria"
  description="Ristorante di pesce con vista mare a Tropea. Cucina calabrese di tradizione con pesce fresco del giorno. Prenota il tuo tavolo."
  transparentNav
>
  <!-- 1. Hero -->
  <Hero
    title={restaurant.name}
    subtitle={restaurant.tagline}
    ctaPrimary={{ text: "Prenota un Tavolo", href: "/prenota/" }}
    ctaSecondary={{ text: "Scopri il Menu", href: "/menu/" }}
  />

  <!-- 2. Chi Siamo brief -->
  <section class="py-20 md:py-28">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div class="grid items-center gap-12 md:grid-cols-2">
        <!-- Text left -->
        <div data-reveal="fade-right">
          <h2 class="font-heading text-2xl font-bold text-navy md:text-4xl">
            La Famiglia Ferraro, <br />dal 1985 a Tropea
          </h2>
          <div class="mt-3 h-0.5 w-10 bg-gold"></div>
          <p class="mt-6 text-text-light leading-relaxed">
            Siamo una famiglia di pescatori e cuochi da tre generazioni. Lo chef Marco Ferraro
            ha trasformato le ricette della nonna in una cucina che celebra il mare della Calabria,
            con pesce fresco ogni giorno e ingredienti del territorio.
          </p>
          <p class="mt-4 text-text-light leading-relaxed">
            Ogni piatto racconta una storia di tradizione, di mare, di Tropea. Benvenuti alla
            nostra tavola.
          </p>
          <a
            href="/chi-siamo/"
            class="mt-8 inline-flex items-center gap-1 font-semibold text-gold hover:text-gold-light transition-colors"
          >
            Scopri la nostra storia
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
        <!-- Image right -->
        <div data-reveal="fade-left">
          <div class="border-2 border-gold/20 rounded-xl overflow-hidden">
            <img
              src="/images/home/chi-siamo.jpg"
              alt="La famiglia Ferraro nel ristorante"
              width="800"
              height="600"
              loading="lazy"
              class="w-full aspect-[4/3] object-cover"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Recensioni — infinite scroll carousel -->
  <section class="py-20 md:py-28 bg-sand-dark overflow-hidden">
    <div class="mx-auto max-w-7xl px-4 md:px-8" data-reveal="fade-up">
      <SectionTitle title="Cosa Dicono i Nostri Ospiti" />
    </div>
    <div
      id="testimonials-carousel"
      class="relative cursor-grab active:cursor-grabbing select-none"
    >
      <div id="testimonials-track" class="flex gap-6 will-change-transform">
        {[...testimonials, ...testimonials, ...testimonials].map((t) => (
          <TestimonialCard name={t.name} text={t.text} rating={t.rating} />
        ))}
      </div>
    </div>

    <!-- Review platform badges -->
    <div class="mx-auto max-w-7xl px-4 md:px-8 mt-12" data-reveal="fade-up">
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center sm:gap-8">
        <a
          href={restaurant.reviews?.google?.url || "#"}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 rounded-lg border border-sand-dark bg-white px-5 py-3 shadow-sm transition-all hover:shadow-md hover:-translate-y-0.5"
        >
          <svg class="h-6 w-6" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1Z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23Z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62Z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53Z"/></svg>
          <div>
            <div class="flex items-center gap-1">
              <span class="text-sm font-bold text-navy">{restaurant.reviews?.google?.rating}</span>
              <div class="flex">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg class:list={["h-3.5 w-3.5", i < Math.round(restaurant.reviews?.google?.rating || 0) ? "text-gold" : "text-sand-dark"]} fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292z"/></svg>
                ))}
              </div>
            </div>
            <p class="text-xs text-text-light">{restaurant.reviews?.google?.count} recensioni su Google</p>
          </div>
        </a>
        <a
          href={restaurant.reviews?.tripadvisor?.url || "#"}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 rounded-lg border border-sand-dark bg-white px-5 py-3 shadow-sm transition-all hover:shadow-md hover:-translate-y-0.5"
        >
          <svg class="h-6 w-6" fill="#34E0A1" viewBox="0 0 24 24"><path d="M12.006 4.295c-2.67 0-5.338.784-7.645 2.353H0l1.963 2.135a5.997 5.997 0 0 0 4.04 10.43 5.976 5.976 0 0 0 4.075-1.6L12 19.51l1.922-1.897a5.976 5.976 0 0 0 4.075 1.6 5.997 5.997 0 0 0 4.04-10.43L24 6.648h-4.35a13.573 13.573 0 0 0-7.644-2.353zM6.003 17.213a3.997 3.997 0 1 1 0-7.994 3.997 3.997 0 0 1 0 7.994zm11.994 0a3.997 3.997 0 1 1 0-7.994 3.997 3.997 0 0 1 0 7.994zM6.003 11.219a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm11.994 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4z"/></svg>
          <div>
            <div class="flex items-center gap-1">
              <span class="text-sm font-bold text-navy">{restaurant.reviews?.tripadvisor?.rating}</span>
              <div class="flex">
                {Array.from({ length: 5 }).map((_, i) => (
                  <svg class:list={["h-3.5 w-3.5", i < Math.round(restaurant.reviews?.tripadvisor?.rating || 0) ? "text-[#34E0A1]" : "text-sand-dark"]} fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 0 0 .95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 0 0-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 0 0-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 0 0-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 0 0 .951-.69l1.07-3.292z"/></svg>
                ))}
              </div>
            </div>
            <p class="text-xs text-text-light">{restaurant.reviews?.tripadvisor?.count} recensioni su TripAdvisor</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener("astro:page-load", () => {
      const carousel = document.getElementById("testimonials-carousel");
      const track = document.getElementById("testimonials-track");
      if (!carousel || !track) return;

      const cards = track.children;
      const totalOriginal = cards.length / 3;
      const gap = 24;

      function getSetWidth() {
        let w = 0;
        for (let i = 0; i < totalOriginal; i++) {
          w += (cards[i] as HTMLElement).offsetWidth + gap;
        }
        return w;
      }

      let setWidth = getSetWidth();
      let pos = -setWidth;
      let speed = -0.5;
      let animId: number | null = null;
      let isDragging = false;
      let dragStartX = 0;
      let dragStartPos = 0;
      let lastDragX = 0;
      let dragVelocity = 0;
      let isPaused = false;

      function applyTransform() {
        track.style.transform = `translate3d(${pos}px, 0, 0)`;
      }

      function wrapPos() {
        if (pos > 0) pos -= setWidth;
        if (pos < -setWidth * 2) pos += setWidth;
      }

      function animate() {
        if (!isDragging && !isPaused) {
          pos += speed;
          wrapPos();
          applyTransform();
        }
        animId = requestAnimationFrame(animate);
      }

      const abortController = new AbortController();
      const sig = abortController.signal;

      document.addEventListener("astro:before-swap", () => {
        if (animId !== null) cancelAnimationFrame(animId);
        abortController.abort();
      }, { once: true });

      window.addEventListener("resize", () => {
        setWidth = getSetWidth();
        pos = -setWidth;
        applyTransform();
      }, { signal: sig });

      carousel.addEventListener("mouseenter", () => { isPaused = true; });
      carousel.addEventListener("mouseleave", () => {
        if (!isDragging) isPaused = false;
      });

      carousel.addEventListener("mousedown", (e) => {
        isDragging = true;
        isPaused = true;
        dragStartX = e.clientX;
        dragStartPos = pos;
        lastDragX = e.clientX;
        dragVelocity = 0;
        e.preventDefault();
      });

      window.addEventListener("mousemove", (e) => {
        if (!isDragging) return;
        const dx = e.clientX - dragStartX;
        dragVelocity = e.clientX - lastDragX;
        lastDragX = e.clientX;
        pos = dragStartPos + dx;
        wrapPos();
        applyTransform();
      }, { signal: sig });

      window.addEventListener("mouseup", () => {
        if (!isDragging) return;
        isDragging = false;
        isPaused = false;
        if (Math.abs(dragVelocity) > 1) {
          let momentum = dragVelocity * 0.95;
          function inertia() {
            if (isDragging || Math.abs(momentum) < 0.3) return;
            pos += momentum;
            momentum *= 0.95;
            wrapPos();
            applyTransform();
            requestAnimationFrame(inertia);
          }
          requestAnimationFrame(inertia);
        }
      }, { signal: sig });

      carousel.addEventListener("touchstart", (e) => {
        isDragging = true;
        isPaused = true;
        dragStartX = e.touches[0].clientX;
        dragStartPos = pos;
        lastDragX = e.touches[0].clientX;
        dragVelocity = 0;
      }, { passive: true });

      carousel.addEventListener("touchmove", (e) => {
        if (!isDragging) return;
        const dx = e.touches[0].clientX - dragStartX;
        dragVelocity = e.touches[0].clientX - lastDragX;
        lastDragX = e.touches[0].clientX;
        pos = dragStartPos + dx;
        wrapPos();
        applyTransform();
      }, { passive: true });

      carousel.addEventListener("touchend", () => {
        if (!isDragging) return;
        isDragging = false;
        isPaused = false;
        if (Math.abs(dragVelocity) > 1) {
          let momentum = dragVelocity * 0.95;
          function inertia() {
            if (isDragging || Math.abs(momentum) < 0.3) return;
            pos += momentum;
            momentum *= 0.95;
            wrapPos();
            applyTransform();
            requestAnimationFrame(inertia);
          }
          requestAnimationFrame(inertia);
        }
      });

      carousel.addEventListener("click", (e) => {
        if (Math.abs(dragVelocity) > 2) e.preventDefault();
      }, true);

      applyTransform();
      animId = requestAnimationFrame(animate);
    });
  </script>

  <!-- 4. Dual image showcase -->
  <section class="py-20 md:py-28 bg-white overflow-hidden">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <!-- Mobile: stacked with staggered reveal -->
      <div class="flex flex-col gap-6 md:hidden">
        <div data-reveal="fade-right" class="overflow-hidden rounded-xl">
          <img
            src="/images/home/dual-image-sinistra.jpg"
            alt="Interno del ristorante con archi in pietra"
            width="600"
            height="800"
            loading="lazy"
            class="w-full aspect-[3/4] object-cover"
          />
        </div>
        <div data-reveal="fade-left" class="overflow-hidden rounded-xl">
          <img
            src="/images/home/dual-image-destra.jpg"
            alt="Terrazza con vista mare al tramonto"
            width="600"
            height="800"
            loading="lazy"
            class="w-full aspect-[3/4] object-cover"
          />
        </div>
      </div>
      <!-- Desktop: 2/5 left (offset down) + 3/5 right (slides up on scroll) -->
      <div class="hidden md:grid md:grid-cols-5 md:gap-8 md:items-start" id="dual-image-section">
        <div class="col-span-2 overflow-hidden rounded-xl" id="dual-image-left">
          <img
            src="/images/home/dual-image-sinistra.jpg"
            alt="Interno del ristorante con archi in pietra"
            width="600"
            height="800"
            loading="lazy"
            class="w-full aspect-[3/4] object-cover"
          />
        </div>
        <div class="col-span-3 overflow-hidden rounded-xl" id="dual-image-right">
          <img
            src="/images/home/dual-image-destra.jpg"
            alt="Terrazza con vista mare al tramonto"
            width="900"
            height="1200"
            loading="lazy"
            class="w-full h-full object-cover"
          />
        </div>
      </div>
      <div class="mt-12 text-center" data-reveal="fade-up">
        <a
          href="/menu/"
          class="inline-flex items-center gap-2 rounded-md bg-gold px-8 py-3 text-base font-bold text-white shadow-sm transition-all duration-300 hover:bg-gold-light hover:shadow-md"
        >
          Scopri il Nostro Menu
          <svg class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener("astro:page-load", () => {
      const rightImg = document.getElementById("dual-image-right");
      const leftImg = document.getElementById("dual-image-left");
      const section = document.getElementById("dual-image-section");
      if (!rightImg || !leftImg || !section || window.innerWidth < 768) return;

      const leftInner = leftImg.querySelector("img") as HTMLElement;
      const rightInner = rightImg.querySelector("img") as HTMLElement;

      // Right image = left image height + 40px
      function syncHeight() {
        rightImg!.style.height = `${leftImg!.offsetHeight + 40}px`;
      }
      syncHeight();
      window.addEventListener("resize", syncHeight, { passive: true });

      function updatePosition() {
        const rect = section!.getBoundingClientRect();
        const vh = window.innerHeight;
        if (rect.bottom < 0 || rect.top > vh) return;
        const progress = Math.min(Math.max((vh - rect.top) / (vh + rect.height), 0), 1);
        // Counter-scroll: left moves down, right moves up
        const leftY = -40 + progress * 80;
        const rightY = 80 - progress * 120;
        // Subtle zoom on inner images
        const leftScale = 1 + progress * 0.06;
        const rightScale = 1.06 - progress * 0.04;
        leftImg!.style.transform = `translate3d(0, ${leftY}px, 0)`;
        rightImg!.style.transform = `translate3d(0, ${rightY}px, 0)`;
        if (leftInner) leftInner.style.transform = `scale(${leftScale})`;
        if (rightInner) rightInner.style.transform = `scale(${rightScale})`;
      }

      window.addEventListener("scroll", updatePosition, { passive: true });
      updatePosition();

      document.addEventListener("astro:before-swap", () => {
        window.removeEventListener("scroll", updatePosition);
        window.removeEventListener("resize", syncHeight);
      }, { once: true });
    });
  </script>

  <!-- 5. Parallax photo break -->
  <section class="parallax-section relative h-[85vh] overflow-hidden" aria-label="Vista del ristorante">
    <div class="parallax-bg absolute inset-0 bg-navy">
      <video
        src="/images/home/video-parallax.mp4"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        class="h-full w-full object-cover"
      ></video>
    </div>
    <div class="absolute inset-0 bg-navy/60"></div>
    <div class="relative flex h-full items-center justify-center text-center px-4">
      <div data-reveal="fade-up">
        <p class="font-heading text-2xl font-bold text-white md:text-4xl lg:text-5xl drop-shadow-lg italic">
          "Dove il mare incontra la tradizione,<br class="hidden sm:inline" /> ogni piatto racconta la nostra storia."
        </p>
        <div class="mt-4 h-0.5 w-16 bg-gold mx-auto"></div>
      </div>
    </div>
  </section>

  <!-- 6. Orari + Mappa -->
  <section class="py-20 md:py-28">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div data-reveal="fade-up">
        <SectionTitle title="Vieni a Trovarci" />
      </div>
      <div class="grid gap-12 md:grid-cols-2 items-start">
        <!-- Orari -->
        <div data-reveal="fade-right">
          <h3 class="font-heading text-xl font-semibold text-navy mb-6">Orari di Apertura</h3>
          <table class="w-full text-sm border-collapse rounded-lg overflow-hidden shadow-sm text-xs sm:text-sm">
            <thead>
              <tr class="bg-navy text-white">
                <th class="px-4 py-3 text-left font-semibold">Giorno</th>
                <th class="px-4 py-3 text-left font-semibold">Pranzo</th>
                <th class="px-4 py-3 text-left font-semibold">Cena</th>
              </tr>
            </thead>
            <tbody>
              {restaurant.hours.map((row) => (
                <tr class="even:bg-sand-dark border-b border-sand-dark last:border-0">
                  <td class="px-4 py-3 font-medium text-navy">{row.days}</td>
                  <td class:list={["px-4 py-3", row.lunch === "Chiuso" ? "text-text-light italic" : "text-text"]}>
                    {row.lunch}
                  </td>
                  <td class:list={["px-4 py-3", row.dinner === "Chiuso" ? "text-text-light italic" : "text-text"]}>
                    {row.dinner}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <p class="mt-4 text-sm text-text-light">
            <strong class="text-navy">Indirizzo:</strong> {restaurant.address.street}, {restaurant.address.city} ({restaurant.address.province})
          </p>
          <p class="mt-1 text-sm text-text-light">
            <strong class="text-navy">Telefono:</strong>{" "}
            <a href={phoneHref} class="hover:text-gold transition-colors">{restaurant.phone}</a>
          </p>
        </div>
        <!-- Mappa -->
        <div data-reveal="fade-left">
          <GoogleMap
            lat={restaurant.coordinates.lat}
            lng={restaurant.coordinates.lng}
            title={restaurant.name}
          />
        </div>
      </div>
    </div>
  </section>

  <!-- 7. CTA Finale -->
  <section class="relative py-20 md:py-28 text-white overflow-hidden">
    <img
      src="/images/home/cta-finale.jpg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-navy/75"></div>
    <div class="relative mx-auto max-w-7xl px-4 md:px-8 text-center" data-reveal="fade-up">
      <SectionTitle
        title="Prenota il Tuo Tavolo"
        subtitle="Chiamaci o scrivici su WhatsApp per prenotare"
        light={true}
      />
      <div class="flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href={phoneHref}
          class="rounded-md border-2 border-white px-8 py-3 text-base font-bold text-white transition-all hover:bg-white hover:text-navy"
        >
          {restaurant.phone}
        </a>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-md bg-gold px-8 py-3 text-base font-bold text-white transition-all hover:bg-gold-light hover:scale-[1.02] hover:shadow-lg"
        >
          Scrivici su WhatsApp
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
