---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import ValueCard from "../components/about/ValueCard.astro";
import Timeline from "../components/about/Timeline.astro";
import restaurantData from "../data/restaurant.json";

const timelineEvents = [
  { year: "1985", title: "La Fondazione", description: "Nonno Giuseppe Ferraro apre la Taverna del Porto con sole 8 tavole e la passione per il mare." },
  { year: "1998", title: "Prima Stella", description: "La Taverna riceve la prima stella nella guida regionale dei ristoranti di Calabria." },
  { year: "2010", title: "La Terrazza sul Mare", description: "Grande ristrutturazione: nasce la terrazza panoramica con vista sullo Stromboli e le Isole Eolie." },
  { year: "2023", title: "Terza Generazione", description: "Chef Marco Ferraro prende la guida della cucina, portando innovazione nel rispetto della tradizione." },
];

const values = [
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>`,
    title: "Ingredienti Locali",
    text: "Ogni mattina selezioniamo il pescato migliore direttamente dai pescatori di Tropea. Verdure e olio provengono da produttori calabresi che conosciamo da generazioni.",
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>`,
    title: "Tradizione",
    text: "Le ricette della nonna Maria sono il cuore del nostro menu. Ogni piatto racconta una storia di famiglia, tramandata con amore da tre generazioni.",
  },
  {
    icon: `<svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" /></svg>`,
    title: "Sostenibilità",
    text: "Rispettiamo il mare che ci nutre. Pesca sostenibile, riduzione degli sprechi e packaging eco-friendly sono i nostri impegni quotidiani.",
  },
];
---

<BaseLayout
  title="Chi Siamo | La Nostra Storia"
  description="Dal 1985, la famiglia Ferraro porta in tavola i sapori del mare di Tropea. Scopri la nostra storia, i nostri valori e la passione per la cucina calabrese."
  breadcrumbs={[{ label: "Home", href: "/" }, { label: "Chi Siamo" }]}
>
  <section class="pt-10 md:pt-14 pb-16">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div data-reveal="fade-up">
        <SectionTitle
          title="La Nostra Storia"
          subtitle="Una famiglia, il mare e la passione per la cucina calabrese dal 1985"
        />
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div class="grid gap-12 md:grid-cols-2 items-center">
        <div data-reveal="fade-right" class="order-2 md:order-1 space-y-6 text-text-light leading-relaxed">
          <p>
            Tutto è iniziato nel 1985, quando Nonno Giuseppe Ferraro — pescatore da una vita intera — decise che il pesce più fresco di Tropea meritava una tavola degna. Con otto tavoli, una cucina minuscola e un amore sconfinato per il mare, nacque la <strong class="text-navy font-semibold">Taverna del Porto</strong>.
          </p>
          <p>
            Da allora, tre generazioni della famiglia Ferraro hanno portato avanti la stessa promessa: <em>portare il mare in tavola, con rispetto e passione</em>. Ogni mattina, prima dell'alba, il nostro pesce viene selezionato direttamente dalle barche dei pescatori locali, gli stessi che rifornivano Nonno Giuseppe quarant'anni fa.
          </p>
          <p>
            La nostra cucina è un dialogo tra tradizione e creatività. Le ricette della nonna Maria — i suoi spaghetti allo scoglio, il polpo alla griglia, il tiramisu che faceva piangere di gioia — convivono con le creazioni di Chef Marco, che ha portato una ventata di freschezza senza mai tradire le radici.
          </p>
          <p>
            Oggi la Taverna del Porto è un punto di riferimento per chi cerca <strong class="text-navy font-semibold">l'autentica cucina di mare calabrese</strong>. La terrazza affacciata sul Tirreno, dove lo sguardo si perde tra le Isole Eolie e lo Stromboli, è il nostro palcoscenico preferito per regalarvi serate indimenticabili.
          </p>
        </div>
        <div data-reveal="fade-left" class="order-1 md:order-2">
          <img
            src="/images/chi-siamo/chi-siamo-famiglia.jpg"
            alt="La famiglia Ferraro nella cucina della Taverna del Porto"
            width="600"
            height="750"
            loading="lazy"
            class="rounded-xl border-2 border-gold/20 w-full object-cover"
            style="aspect-ratio: 4/5;"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-sand-dark">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div class="grid gap-12 md:grid-cols-2 items-center">
        <div data-reveal="zoom-in">
          <img
            src="/images/chi-siamo/chi-siamo-chef.jpg"
            alt={`${restaurantData.chef.name} - ${restaurantData.chef.title}`}
            width="600"
            height="800"
            loading="lazy"
            class="rounded-xl w-full object-cover"
            style="aspect-ratio: 3/4;"
          />
        </div>
        <div data-reveal="fade-up">
          <h2 class="font-heading text-3xl font-bold text-navy md:text-4xl">{restaurantData.chef.name}</h2>
          <p class="mt-2 text-gold font-semibold">{restaurantData.chef.title}</p>
          <div class="mt-1 h-0.5 w-10 bg-gold"></div>
          <p class="mt-6 text-text-light leading-relaxed">{restaurantData.chef.bio}</p>
          <p class="mt-4 text-text-light leading-relaxed">
            Dopo anni di formazione tra Napoli, Roma e la Costa Azzurra, Marco è tornato a Tropea con una missione chiara: innovare senza dimenticare. Il suo menu cambia con le stagioni e con il mare, perché — come diceva Nonno Giuseppe — "il pesce decide lui cosa cucini oggi".
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div data-reveal="fade-up">
        <SectionTitle title="I Nostri Valori" subtitle="I principi che guidano ogni giorno il nostro lavoro" />
      </div>
      <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3" data-reveal-stagger>
        {values.map((value) => (
          <div data-reveal="fade-up">
            <ValueCard icon={value.icon} title={value.title} text={value.text} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-sand-dark">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div data-reveal="fade-up">
        <SectionTitle title="Il Nostro Percorso" subtitle="Quarant'anni di storia, passione e sapori" />
      </div>
      <div class="mt-12" data-reveal="fade-up">
        <Timeline events={timelineEvents} />
      </div>
    </div>
  </section>
</BaseLayout>
