---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import AnimateOnScroll from "../components/ui/AnimateOnScroll.astro";
import GoogleMap from "../components/ui/GoogleMap.astro";
import ContactForm from "../components/contact/ContactForm.astro";
import restaurantData from "../data/restaurant.json";

const whatsappHref = `https://wa.me/${restaurantData.whatsapp.replace(/[^0-9]/g, "")}?text=${encodeURIComponent(restaurantData.whatsappMessage)}`;
---

<BaseLayout
  title="Contatti | Prenota a Tropea"
  description="Prenota il tuo tavolo alla Taverna del Porto. Indirizzo, telefono, email e orari di apertura del nostro ristorante a Tropea."
>
  <!-- Page header -->
  <section class="pt-32 pb-16">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <SectionTitle
        title="Contattaci"
        subtitle="Prenota il tuo tavolo o scrivici per qualsiasi informazione"
      />
    </div>
  </section>

  <!-- Contact info + Form -->
  <section class="pb-20">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- Left: Contact info + Hours -->
        <AnimateOnScroll animation="slide-right">
          <div class="space-y-10">
            <!-- Contact details -->
            <div class="space-y-4">
              <h3 class="font-heading text-xl font-bold text-navy">Informazioni</h3>
              <div class="space-y-3 text-text-light">
                <!-- Address -->
                <div class="flex items-start gap-3">
                  <svg class="h-5 w-5 text-gold mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                  </svg>
                  <div>
                    <p>{restaurantData.address.street}</p>
                    <p>{restaurantData.address.cap} {restaurantData.address.city} ({restaurantData.address.province})</p>
                  </div>
                </div>
                <!-- Phone -->
                <div class="flex items-center gap-3">
                  <svg class="h-5 w-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                  </svg>
                  <a href={`tel:${restaurantData.phone}`} class="hover:text-gold transition-colors">{restaurantData.phone}</a>
                </div>
                <!-- Email -->
                <div class="flex items-center gap-3">
                  <svg class="h-5 w-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                  </svg>
                  <a href={`mailto:${restaurantData.email}`} class="hover:text-gold transition-colors">{restaurantData.email}</a>
                </div>
                <!-- WhatsApp -->
                <div class="flex items-center gap-3">
                  <svg class="h-5 w-5 text-[#25D366] shrink-0" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                  </svg>
                  <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="hover:text-gold transition-colors">Scrivici su WhatsApp</a>
                </div>
              </div>
            </div>

            <!-- Opening hours -->
            <div>
              <h3 class="font-heading text-xl font-bold text-navy mb-4">Orari di Apertura</h3>
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-sand-dark">
                    <th class="pb-2 text-left font-semibold text-navy">Giorno</th>
                    <th class="pb-2 text-left font-semibold text-navy">Pranzo</th>
                    <th class="pb-2 text-left font-semibold text-navy">Cena</th>
                  </tr>
                </thead>
                <tbody>
                  {restaurantData.hours.map((h) => (
                    <tr class="border-b border-sand-dark/50 even:bg-sand-dark/30">
                      <td class="py-2 font-medium text-navy">{h.days}</td>
                      <td class="py-2 text-text-light">{h.lunch}</td>
                      <td class="py-2 text-text-light">{h.dinner}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </AnimateOnScroll>

        <!-- Right: Contact Form -->
        <AnimateOnScroll animation="slide-left">
          <div class="rounded-xl border border-sand-dark bg-white p-8 shadow-sm">
            <h3 class="font-heading text-xl font-bold text-navy mb-6">Scrivici un Messaggio</h3>
            <ContactForm />
          </div>
        </AnimateOnScroll>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="pb-20">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <AnimateOnScroll animation="fade-up">
        <GoogleMap
          lat={restaurantData.coordinates.lat}
          lng={restaurantData.coordinates.lng}
          title="Taverna del Porto - Tropea"
        />
      </AnimateOnScroll>
    </div>
  </section>
</BaseLayout>
