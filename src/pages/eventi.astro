---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/ui/SectionTitle.astro";
import Breadcrumbs from "../components/ui/Breadcrumbs.astro";
import eventsData from "../data/events.json";
import restaurantData from "../data/restaurant.json";

const whatsappHref = `https://wa.me/${restaurantData.whatsapp.replace(/[^0-9]/g, "")}?text=${encodeURIComponent("Ciao! Vorrei informazioni su un vostro evento.")}`;

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + "T00:00:00");
  return d.toLocaleDateString("it-IT", { weekday: "long", day: "numeric", month: "long", year: "numeric" });
}
---

<BaseLayout
  title="Eventi | Serate Speciali a Tropea"
  description="Scopri gli eventi della Taverna del Porto: degustazioni, serate a tema, cooking class e cene speciali sulla terrazza con vista mare."
>
  <section class="pt-24 md:pt-32 pb-16">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div class="mb-6">
        <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Eventi" }]} />
      </div>
      <div data-reveal="fade-up">
        <SectionTitle
          title="Eventi e Serate Speciali"
          subtitle="Esperienze uniche tra sapori, musica e il mare di Tropea"
        />
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div class="grid gap-8 md:grid-cols-2">
        {eventsData.map((event) => (
          <article data-reveal="fade-up" class="group rounded-xl border border-sand-dark bg-white overflow-hidden shadow-sm transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
            <div class="bg-navy px-6 py-4 flex items-center justify-between">
              <div>
                <p class="text-gold font-heading text-lg font-bold">{formatDate(event.date)}</p>
                <p class="text-white/70 text-sm">Ore {event.time}</p>
              </div>
              <span class="rounded-full bg-gold/20 px-3 py-1 text-xs font-bold text-gold uppercase tracking-wider">
                {event.tag}
              </span>
            </div>
            <div class="p-6">
              <h3 class="font-heading text-xl font-bold text-navy">{event.title}</h3>
              <p class="mt-3 text-sm text-text-light leading-relaxed">{event.description}</p>
              <div class="mt-6 flex items-center justify-between">
                <span class="text-2xl font-bold text-gold">&euro;{event.price}<span class="text-sm font-normal text-text-light"> / persona</span></span>
                <a
                  href={whatsappHref}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="rounded-md bg-gold px-5 py-2 text-sm font-bold text-navy transition-all hover:bg-gold-light hover:scale-[1.02]"
                >
                  Prenota
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="mx-auto max-w-4xl px-4 md:px-8" data-reveal="fade-up">
      <div class="rounded-xl bg-sand-dark p-8 md:p-12 text-center">
        <h2 class="font-heading text-2xl font-bold text-navy md:text-3xl">Organizzi un Evento Privato?</h2>
        <p class="mt-4 text-text-light max-w-2xl mx-auto leading-relaxed">
          La nostra terrazza con vista mare e la sala interna sono disponibili per cene private, feste di compleanno, anniversari e eventi aziendali. Creiamo un menu personalizzato per la tua occasione speciale.
        </p>
        <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a
            href={whatsappHref}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-md bg-gold px-8 py-3 font-bold text-navy transition-all hover:bg-gold-light hover:scale-[1.02]"
          >
            Scrivici su WhatsApp
          </a>
          <a
            href="/contatti/"
            class="rounded-md border-2 border-navy px-8 py-3 font-bold text-navy transition-all hover:bg-navy hover:text-white"
          >
            Contattaci
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
