---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionTitle from "../../components/ui/SectionTitle.astro";
import GoogleMap from "../../components/ui/GoogleMap.astro";
import Breadcrumbs from "../../components/ui/Breadcrumbs.astro";
import restaurantData from "../../data/en/restaurant.json";
import { t } from "../../i18n/ui";

const lang = "en" as const;
const whatsappHref = `https://wa.me/${restaurantData.whatsapp.replace(/[^0-9]/g, "")}?text=${encodeURIComponent(restaurantData.whatsappMessage)}`;
---

<BaseLayout
  title="Contact | Book in Tropea"
  description="Book your table at Taverna del Porto. Address, phone, email and opening hours of our restaurant in Tropea."
  lang={lang}
>
  <section class="pt-24 md:pt-32 pb-16">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div class="mb-6">
        <Breadcrumbs items={[{ label: "Home", href: "/en/" }, { label: "Contact" }]} />
      </div>
      <div data-reveal="fade-up">
        <SectionTitle title="Contact Us" subtitle="Book your table or write to us for any information" />
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div class="grid gap-12 lg:grid-cols-2">
        <div data-reveal="fade-right">
          <div class="space-y-10">
            <div class="space-y-4">
              <h3 class="font-heading text-xl font-bold text-navy">{t(lang, "contact.info")}</h3>
              <div class="space-y-3 text-text-light">
                <div class="flex items-start gap-3">
                  <svg class="h-5 w-5 text-gold mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
                  <div>
                    <p>{restaurantData.address.street}</p>
                    <p>{restaurantData.address.cap} {restaurantData.address.city} ({restaurantData.address.province})</p>
                  </div>
                </div>
                <div class="flex items-center gap-3">
                  <svg class="h-5 w-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
                  <a href={`tel:${restaurantData.phone}`} class="hover:text-gold transition-colors">{restaurantData.phone}</a>
                </div>
                <div class="flex items-center gap-3">
                  <svg class="h-5 w-5 text-gold shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
                  <a href={`mailto:${restaurantData.email}`} class="hover:text-gold transition-colors">{restaurantData.email}</a>
                </div>
                <div class="flex items-center gap-3">
                  <svg class="h-5 w-5 text-[#25D366] shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
                  <a href={whatsappHref} target="_blank" rel="noopener noreferrer" class="hover:text-gold transition-colors">{t(lang, "contact.whatsapp")}</a>
                </div>
              </div>
            </div>

            <div>
              <h3 class="font-heading text-xl font-bold text-navy mb-4">{t(lang, "contact.hours")}</h3>
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-sand-dark">
                    <th class="pb-2 text-left font-semibold text-navy">{t(lang, "contact.day")}</th>
                    <th class="pb-2 text-left font-semibold text-navy">{t(lang, "contact.lunch")}</th>
                    <th class="pb-2 text-left font-semibold text-navy">{t(lang, "contact.dinner")}</th>
                  </tr>
                </thead>
                <tbody>
                  {restaurantData.hours.map((h) => (
                    <tr class="border-b border-sand-dark/50 even:bg-sand-dark/30">
                      <td class="py-2 font-medium text-navy">{h.days}</td>
                      <td class="py-2 text-text-light">{h.lunch}</td>
                      <td class="py-2 text-text-light">{h.dinner}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <div data-reveal="fade-left">
          <div class="rounded-xl border border-sand-dark bg-white p-5 sm:p-8 shadow-sm">
            <h3 class="font-heading text-xl font-bold text-navy mb-6">{t(lang, "contact.writeUs")}</h3>
            <form id="contact-form" class="space-y-6" novalidate>
              <div class="hidden" aria-hidden="true">
                <label>Do not fill this field <input type="text" name="bot-field" tabindex="-1" autocomplete="off" /></label>
              </div>
              <div>
                <label for="name" class="block text-sm font-semibold text-navy mb-1">{t(lang, "form.name")} *</label>
                <input type="text" id="name" name="name" required autocomplete="name" class="w-full rounded-md border border-sand-dark bg-white px-4 py-3 text-text transition-colors focus:border-gold focus:outline-none focus:ring-2 focus:ring-gold/20" />
              </div>
              <div>
                <label for="email" class="block text-sm font-semibold text-navy mb-1">{t(lang, "form.email")} *</label>
                <input type="email" id="email" name="email" required autocomplete="email" class="w-full rounded-md border border-sand-dark bg-white px-4 py-3 text-text transition-colors focus:border-gold focus:outline-none focus:ring-2 focus:ring-gold/20" />
              </div>
              <div>
                <label for="phone" class="block text-sm font-semibold text-navy mb-1">{t(lang, "form.phone")}</label>
                <input type="tel" id="phone" name="phone" autocomplete="tel" class="w-full rounded-md border border-sand-dark bg-white px-4 py-3 text-text transition-colors focus:border-gold focus:outline-none focus:ring-2 focus:ring-gold/20" />
              </div>
              <div>
                <label for="message" class="block text-sm font-semibold text-navy mb-1">{t(lang, "form.message")} *</label>
                <textarea id="message" name="message" required rows="5" class="w-full rounded-md border border-sand-dark bg-white px-4 py-3 text-text transition-colors focus:border-gold focus:outline-none focus:ring-2 focus:ring-gold/20 resize-y"></textarea>
              </div>
              <button type="submit" class="w-full sm:w-auto rounded-md bg-gold px-8 py-3 font-bold text-navy transition-all hover:bg-gold-light hover:scale-[1.02] hover:shadow-md focus:outline-2 focus:outline-offset-2 focus:outline-gold">{t(lang, "form.send")}</button>
            </form>
            <div id="form-success" class="hidden rounded-xl border border-gold/30 bg-gold/5 p-8 text-center">
              <svg class="mx-auto h-12 w-12 text-gold mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
              <h3 class="font-heading text-xl font-bold text-navy">{t(lang, "form.success.title")}</h3>
              <p class="mt-2 text-text-light">{t(lang, "form.success.text")}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-reveal-stagger>
        <div class="rounded-xl border border-sand-dark bg-white p-6 text-center" data-reveal="fade-up">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-gold/10 text-gold mb-4"><svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z" /></svg></div>
          <h4 class="font-heading text-sm font-bold text-navy mb-2">{t(lang, "contact.payments")}</h4>
          <p class="text-xs text-text-light">{restaurantData.practicalInfo.payments.join(", ")}</p>
        </div>
        <div class="rounded-xl border border-sand-dark bg-white p-6 text-center" data-reveal="fade-up">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-gold/10 text-gold mb-4"><svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 0 0-3.213-9.193 2.056 2.056 0 0 0-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 0 0-10.026 0 1.106 1.106 0 0 0-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12" /></svg></div>
          <h4 class="font-heading text-sm font-bold text-navy mb-2">{t(lang, "contact.parking")}</h4>
          <p class="text-xs text-text-light">{restaurantData.practicalInfo.parking}</p>
        </div>
        <div class="rounded-xl border border-sand-dark bg-white p-6 text-center" data-reveal="fade-up">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-gold/10 text-gold mb-4"><svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" /></svg></div>
          <h4 class="font-heading text-sm font-bold text-navy mb-2">{t(lang, "contact.accessibility")}</h4>
          <p class="text-xs text-text-light">{restaurantData.practicalInfo.accessibility}</p>
        </div>
        <div class="rounded-xl border border-sand-dark bg-white p-6 text-center" data-reveal="fade-up">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-gold/10 text-gold mb-4"><svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" /></svg></div>
          <h4 class="font-heading text-sm font-bold text-navy mb-2">{t(lang, "contact.usefulInfo")}</h4>
          <p class="text-xs text-text-light">{restaurantData.practicalInfo.coverCharge} {restaurantData.practicalInfo.dressCode}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="mx-auto max-w-7xl px-4 md:px-8" data-reveal="fade-up">
      <GoogleMap lat={restaurantData.coordinates.lat} lng={restaurantData.coordinates.lng} title="Taverna del Porto - Tropea" />
    </div>
  </section>
</BaseLayout>

<script>
  document.addEventListener("astro:page-load", () => {
    const form = document.getElementById("contact-form");
    const success = document.getElementById("form-success");
    form?.addEventListener("submit", (e) => { e.preventDefault(); if (!form.checkValidity()) { form.reportValidity(); return; } form.classList.add("hidden"); success?.classList.remove("hidden"); });
  });
</script>
