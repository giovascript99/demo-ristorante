---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionTitle from "../../components/ui/SectionTitle.astro";
import ReservationForm from "../../components/booking/ReservationForm.astro";
import GoogleMap from "../../components/ui/GoogleMap.astro";
import restaurantData from "../../data/en/restaurant.json";
import seoData from "../../data/seo.json";

const reservationJsonLd = {
  "@context": "https://schema.org",
  "@type": "FoodEstablishmentReservation",
  "provider": {
    "@type": "Restaurant",
    "name": restaurantData.name,
    "telephone": restaurantData.phone,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": restaurantData.address.street,
      "addressLocality": restaurantData.address.city,
      "postalCode": restaurantData.address.cap,
      "addressRegion": restaurantData.address.province,
      "addressCountry": restaurantData.address.country,
    },
    "url": `${seoData.siteUrl}/en/`,
    "servesCuisine": restaurantData.cuisineType,
    "priceRange": restaurantData.priceRange,
    "acceptsReservations": "True",
  },
  "potentialAction": {
    "@type": "ReserveAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": `${seoData.siteUrl}/en/book/`,
      "inLanguage": "en-GB",
      "actionPlatform": ["http://schema.org/DesktopWebPlatform", "http://schema.org/MobileWebPlatform"],
    },
    "result": { "@type": "FoodEstablishmentReservation", "name": "Table booking" },
  },
};
---

<BaseLayout
  title="Book a Table | Taverna del Porto"
  description="Book your table online at Taverna del Porto in Tropea. Pick date, time and party size for an unforgettable seafront dining experience."
  lang="en"
  breadcrumbs={[{ label: "Home", href: "/en/" }, { label: "Book" }]}
>
  <script type="application/ld+json" set:html={JSON.stringify(reservationJsonLd)} />

  <section class="pt-10 md:pt-14 pb-12">
    <div class="mx-auto max-w-5xl px-4 md:px-8">
      <div data-reveal="fade-up">
        <SectionTitle
          title="Book Your Table"
          subtitle="A few clicks and your seafront table awaits"
        />
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="mx-auto max-w-5xl px-4 md:px-8">
      <div class="grid gap-10 lg:grid-cols-[1fr_360px]">
        <div data-reveal="fade-up" class="border border-sand-dark bg-white p-6 sm:p-8 shadow-sm">
          <ReservationForm lang="en" />
        </div>

        <aside class="space-y-6" data-reveal="fade-left">
          <div class="border border-sand-dark bg-white p-6">
            <h3 class="font-heading text-lg text-navy mb-3">Need help?</h3>
            <p class="text-sm text-text-light mb-4">For large groups, private events or special requests, call us directly.</p>
            <div class="space-y-2 text-sm">
              <a href={`tel:${restaurantData.phone.replace(/\s/g, "")}`} class="flex items-center gap-2 text-navy hover:text-gold transition-colors">
                <svg class="h-4 w-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                </svg>
                {restaurantData.phone}
              </a>
              <a href={`https://wa.me/${restaurantData.whatsapp.replace(/[^0-9]/g, "")}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-navy hover:text-gold transition-colors">
                <svg class="h-4 w-4 text-gold" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347Zm-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884Zm8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/>
                </svg>
                WhatsApp
              </a>
            </div>
          </div>

          <div class="border border-sand-dark bg-white p-6">
            <h3 class="font-heading text-lg text-navy mb-3">Hours</h3>
            <ul class="space-y-2 text-sm text-text-light">
              {restaurantData.hours.map((h) => (
                <li>
                  <p class="font-semibold text-navy">{h.days}</p>
                  <p>{h.lunch !== "Closed" ? `Lunch: ${h.lunch}` : "Lunch: closed"}</p>
                  <p>{h.dinner !== "Closed" ? `Dinner: ${h.dinner}` : "Dinner: closed"}</p>
                </li>
              ))}
            </ul>
          </div>

          <div class="border-l-4 border-gold bg-gold/5 px-4 py-3">
            <p class="text-xs text-text-light">{restaurantData.practicalInfo.coverCharge}</p>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="pb-20">
    <div class="mx-auto max-w-5xl px-4 md:px-8">
      <div class="mb-6 flex items-center gap-3">
        <svg class="h-5 w-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
        </svg>
        <h3 class="font-heading text-2xl text-navy">Where we are</h3>
      </div>
      <p class="text-sm text-text-light mb-4">{restaurantData.address.street}, {restaurantData.address.cap} {restaurantData.address.city} ({restaurantData.address.province})</p>
      <div data-reveal="fade-up">
        <GoogleMap lat={restaurantData.coordinates.lat} lng={restaurantData.coordinates.lng} title={`${restaurantData.name} - ${restaurantData.address.city}`} />
      </div>
    </div>
  </section>
</BaseLayout>
